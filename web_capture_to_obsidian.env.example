# Copy this file to web_capture_to_obsidian.env and adjust the values for your machine.

# Where the generated Obsidian notes should be written.
# Must be an absolute path.
WEB_CAPTURE_TO_OBSIDIAN_TARGET_DIR="$HOME/Obsidian/Web Capture to Obsidian"

# Optional: use LLM-generated titles, summaries, and tags in standalone Codex shell automation.
# Default is 1. Set to 0 if you want pure rule-based extraction.
# WEB_CAPTURE_TO_OBSIDIAN_USE_LLM="1"
#
# Optional: choose the model used for standalone Codex shell automation.
# WEB_CAPTURE_TO_OBSIDIAN_LLM_MODEL="gpt-5.4"

# Optional: override the Chrome binary path.
# WEB_CAPTURE_TO_OBSIDIAN_CHROME_BIN="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# Optional: override the DevToolsActivePort file path if you use a different Chrome profile.
# WEB_CAPTURE_TO_OBSIDIAN_DEVTOOLS_FILE="$HOME/Library/Application Support/Google/Chrome/DevToolsActivePort"

# Optional: override the timezone used when rendering note timestamps.
# WEB_CAPTURE_TO_OBSIDIAN_TIMEZONE="Asia/Shanghai"
