# Copy this file to x_bookmarks_sync.env and adjust the values for your machine.

# Where the generated Obsidian notes should be written.
X_BOOKMARKS_TARGET_DIR="$HOME/Obsidian/X Bookmarks"

# Optional: override the Chrome binary path.
# X_BOOKMARKS_CHROME_BIN="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# Optional: override the DevToolsActivePort file path if you use a different Chrome profile.
# X_BOOKMARKS_DEVTOOLS_FILE="$HOME/Library/Application Support/Google/Chrome/DevToolsActivePort"

# Optional: override the timezone used when rendering note timestamps.
# X_BOOKMARKS_TIMEZONE="Asia/Shanghai"
